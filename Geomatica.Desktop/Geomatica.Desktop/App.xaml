<Application x:Class="Geomatica.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Geomatica.Desktop.Views"
             xmlns:vms="clr-namespace:Geomatica.Desktop.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ArcGisUisTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vms:MapaViewModel}">
                <views:MapaView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vms:ArchivosViewModel}">
                <views:ArchivosView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vms:CrearProyectoViewModel}">
                <views:CrearProyectoView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vms:FichaProyectoViewModel}">
                <views:FichaProyectoView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vms:EditarProyectoViewModel}">
                <views:EditarProyectoView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
