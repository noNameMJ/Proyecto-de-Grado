<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         PALETA DE COLORES — ArcGIS Pro + UIS (Universidad Industrial de Santander)
         ═══════════════════════════════════════════════════════════ -->

    <!-- UIS Institucional -->
    <Color x:Key="UisGreenColor">#006633</Color>
    <Color x:Key="UisGreenLightColor">#00804A</Color>
    <Color x:Key="UisGoldColor">#D4A017</Color>
    <Color x:Key="UisGoldLightColor">#E8BD45</Color>

    <!-- ArcGIS Pro Dark Chrome -->
    <Color x:Key="ChromeDarkColor">#FF2B2B2B</Color>
    <Color x:Key="ChromeMediumColor">#FF323232</Color>
    <Color x:Key="ChromeLightColor">#FF3F3F46</Color>
    <Color x:Key="ChromeHoverColor">#FF4D4D55</Color>

    <!-- Surfaces -->
    <Color x:Key="SurfaceColor">#FFF5F5F5</Color>
    <Color x:Key="CardColor">#FFFFFFFF</Color>
    <Color x:Key="PanelColor">#FFFAFAFA</Color>
    <Color x:Key="BorderSubtleColor">#FFE0E0E0</Color>
    <Color x:Key="SeparatorColor">#FFCCCCCC</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FF1E1E1E</Color>
    <Color x:Key="TextSecondaryColor">#FF6E6E6E</Color>
    <Color x:Key="TextOnDarkColor">#FFFFFFFF</Color>
    <Color x:Key="TextMutedColor">#FF999999</Color>

    <!-- Status -->
    <Color x:Key="DangerColor">#FFD32F2F</Color>
    <Color x:Key="InfoColor">#FF1976D2</Color>

    <!-- ═══════════════════════════════════════════════════════════
         BRUSHES
         ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="UisGreenBrush"      Color="{StaticResource UisGreenColor}"/>
    <SolidColorBrush x:Key="UisGreenLightBrush"  Color="{StaticResource UisGreenLightColor}"/>
    <SolidColorBrush x:Key="UisGoldBrush"        Color="{StaticResource UisGoldColor}"/>
    <SolidColorBrush x:Key="UisGoldLightBrush"   Color="{StaticResource UisGoldLightColor}"/>

    <SolidColorBrush x:Key="ChromeDarkBrush"     Color="{StaticResource ChromeDarkColor}"/>
    <SolidColorBrush x:Key="ChromeMediumBrush"   Color="{StaticResource ChromeMediumColor}"/>
    <SolidColorBrush x:Key="ChromeLightBrush"    Color="{StaticResource ChromeLightColor}"/>
    <SolidColorBrush x:Key="ChromeHoverBrush"    Color="{StaticResource ChromeHoverColor}"/>

    <SolidColorBrush x:Key="SurfaceBrush"        Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush"           Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="PanelBrush"          Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"   Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush"      Color="{StaticResource SeparatorColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextOnDarkBrush"     Color="{StaticResource TextOnDarkColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"      Color="{StaticResource TextMutedColor}"/>

    <!-- Gradient para barra UIS (verde→oscuro) -->
    <LinearGradientBrush x:Key="UisHeaderGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource UisGreenColor}" Offset="0"/>
        <GradientStop Color="#004D26" Offset="1"/>
    </LinearGradientBrush>

    <!-- Accent gold stripe -->
    <SolidColorBrush x:Key="AccentStripeBrush" Color="{StaticResource UisGoldColor}"/>

    <!-- ═══════════════════════════════════════════════════════════
         TYPOGRAPHY
         ═══════════════════════════════════════════════════════════ -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <FontFamily x:Key="AppFontSemibold">Segoe UI Semibold</FontFamily>

    <!-- ═══════════════════════════════════════════════════════════
         EFECTOS / SOMBRAS  (deben definirse ANTES de los estilos que las usan)
         ═══════════════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2"
                      Direction="270" Color="#000000" Opacity="0.12"/>
    <DropShadowEffect x:Key="ElevatedShadow" BlurRadius="24" ShadowDepth="4"
                      Direction="270" Color="#000000" Opacity="0.18"/>

    <!-- ═══════════════════════════════════════════════════════════
         ESTILOS DE BOTÓN
         ═══════════════════════════════════════════════════════════ -->

    <!-- Botón primario (UIS Green) -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource UisGreenBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource UisGreenLightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#004D26"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón secundario (Gold) -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource UisGoldBrush}"/>
        <Setter Property="Foreground" Value="#1E1E1E"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource UisGoldLightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#B8880F"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón navegación (barra oscura — estilo ArcGIS) -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="2" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ChromeLightBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ChromeHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón de navegación resaltado (Nuevo Proyecto) -->
    <Style x:Key="NavButtonAccent" TargetType="Button" BasedOn="{StaticResource NavButton}">
        <Setter Property="Background" Value="{StaticResource UisGreenBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource UisGreenLightBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Botón ghost / link -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource UisGreenBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#10006633"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón outline (cancelar) -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#08000000"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón flotante mapa (Home, zoom, etc.) — estilo ArcGIS -->
    <Style x:Key="MapToolButton" TargetType="Button">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" SnapsToDevicePixels="True"
                            Effect="{StaticResource CardShadow}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón barra inferior (Archivos) -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E8E8E8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Small clear button (X buttons en filtros) -->
    <Style x:Key="ClearButton" TargetType="Button">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="11" Width="22" Height="22">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#15000000"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TEXTBOX ESTILO
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource UisGreenBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         COMBOBOX ESTILO
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         LABEL ESTILOS
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontSemibold}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,8,0,8"/>
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         CARD / PANEL ESTILOS
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         LISTBOX / LISTVIEW ESTILO
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="ModernListBox" TargetType="ListBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         SEPARATOR ESTILO
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="ModernSeparator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="Margin" Value="0,12"/>
        <Setter Property="Height" Value="1"/>
    </Style>

</ResourceDictionary>
