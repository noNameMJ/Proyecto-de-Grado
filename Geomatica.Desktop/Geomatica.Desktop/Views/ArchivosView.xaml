<UserControl x:Class="Geomatica.Desktop.Views.ArchivosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Geomatica.Desktop.Views"
             xmlns:vm="clr-namespace:Geomatica.Desktop.ViewModels"
             xmlns:models="clr-namespace:Geomatica.Desktop.Models">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type models:CarpetaVirtual}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📁" Margin="0,0,8,0" FontSize="14"/>
                <TextBlock Text="{Binding Nombre}" VerticalAlignment="Center" 
                           FontFamily="{StaticResource AppFont}" FontSize="13"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:ArchivoVirtual}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📄" Margin="0,0,8,0" FontSize="14"/>
                <TextBlock Text="{Binding Nombre}" VerticalAlignment="Center"
                           FontFamily="{StaticResource AppFont}" FontSize="13"/>
            </StackPanel>
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Retirado el Grid.ColumnDefinitions porque el panel izquierdo se ha movido al MapaView -->

        <!-- ══════ CONTENIDO: Explorador de archivos ══════ -->

        <!-- Barra de ruta (breadcrumb) -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="⬆  Arriba" Command="{Binding ArribaCommand}" 
                        Style="{StaticResource ToolbarButton}" Width="90"/>
                <Rectangle Width="1" Height="20" Fill="{StaticResource SeparatorBrush}" Margin="12,0"/>
                <TextBlock Text="Ruta:" VerticalAlignment="Center" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           FontFamily="{StaticResource AppFont}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding RutaActual}" VerticalAlignment="Center" 
                           TextTrimming="CharacterEllipsis" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="{StaticResource AppFont}"/>
            </StackPanel>
        </Border>

        <!-- File list -->
        <ListView Grid.Row="1" 
                  ItemsSource="{Binding Items}" 
                  MouseDoubleClick="ListView_MouseDoubleClick" 
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  BorderThickness="0" Background="White"
                  FontFamily="{StaticResource AppFont}"
                  AllowDrop="True" Drop="ListView_Drop">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Barra inferior -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Subir Archivo" Command="{Binding SubirCommand}" 
                        Style="{StaticResource PrimaryButton}" Padding="14,6"/>
                <Button Content="📁 Nueva Carpeta" Command="{Binding NuevaCarpetaCommand}" 
                        Style="{StaticResource OutlineButton}" Margin="8,0,0,0" Padding="14,6"/>
                <Button Content="⬇️ Descargar" Command="{Binding DescargarCommand}" 
                        Style="{StaticResource OutlineButton}" Margin="8,0,0,0" Padding="14,6"/>
                <Button Content="🗺️ Ver en Mapa" Command="{Binding AbrirEnMapaCommand}" 
                        Style="{StaticResource OutlineButton}" Margin="8,0,0,0" Padding="14,6"/>
                <Button Content="👁️ Abrir Ext." Command="{Binding AbrirCommand}" 
                        Style="{StaticResource OutlineButton}" Margin="8,0,0,0" Padding="14,6"/>
                <Button Content="🗑️ Eliminar" Command="{Binding EliminarCommand}" 
                        Style="{StaticResource OutlineButton}" Margin="8,0,0,0" Padding="14,6"/>
                <TextBlock Text="{Binding Estado}" Margin="16,0,0,0" VerticalAlignment="Center" 
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="{StaticResource AppFont}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
