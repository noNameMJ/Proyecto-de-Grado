<UserControl x:Class="Geomatica.Desktop.Views.BarraFiltrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Width="320" Background="{StaticResource PanelBrush}" 
            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,14,16,16">

                <!-- Encabezado Filtros -->
                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="Filtros" FontWeight="Bold" FontSize="16" 
                               VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource AppFont}"/>
                    <Button Content="Limpiar" Command="{Binding LimpiarFiltrosCommand}" 
                            Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                            FontSize="12"/>
                </DockPanel>

                <Separator Style="{StaticResource ModernSeparator}" Margin="0,0,0,14"/>

                <!-- Palabra clave -->
                <TextBlock Text="Palabra clave" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding PalabraClave, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <!-- Rango temporal -->
                <TextBlock Text="Rango temporal" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <DatePicker SelectedDate="{Binding Desde}" Width="120"/>
                    <Button Content="✕" Command="{Binding LimpiarDesdeCommand}"
                            Style="{StaticResource ClearButton}"
                            VerticalAlignment="Center" Margin="4,0,0,0"
                            ToolTip="Limpiar fecha desde"/>
                    <DatePicker SelectedDate="{Binding Hasta}" Width="120" Margin="8,0,0,0"/>
                    <Button Content="✕" Command="{Binding LimpiarHastaCommand}"
                            Style="{StaticResource ClearButton}"
                            VerticalAlignment="Center" Margin="4,0,0,0"
                            ToolTip="Limpiar fecha hasta"/>
                </StackPanel>

                <!-- Departamento -->
                <TextBlock Text="Departamento" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Departamentos}" 
                          SelectedItem="{Binding SelectedDepartamento, Mode=TwoWay}" 
                          DisplayMemberPath="Nombre" SelectedValuePath="Codigo" 
                          Style="{StaticResource ModernComboBox}" Margin="0,0,0,12"/>

                <!-- Municipio -->
                <TextBlock Text="Municipio" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Areas}" 
                          SelectedItem="{Binding AreaInteres, Mode=TwoWay}" 
                          DisplayMemberPath="Nombre" SelectedValuePath="Codigo" 
                          Style="{StaticResource ModernComboBox}" Margin="0,0,0,12"/>

                <!-- Resumen -->
                <ListBox ItemsSource="{Binding ResultadosResumen}" Height="55" 
                         Style="{StaticResource ModernListBox}"/>

                <Separator Style="{StaticResource ModernSeparator}"/>

                <!-- Resultados -->
                <TextBlock Text="Resultados" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                <ListBox ItemsSource="{Binding ResultadosLista}" 
                         SelectedItem="{Binding SelectedProyecto, Mode=TwoWay}" 
                         DisplayMemberPath="Titulo" Height="195" 
                         Style="{StaticResource ModernListBox}"/>

                <!-- Descargar -->
                <Button Content="⬇  Descargar seleccionado" 
                        Command="{Binding DescargarCommand}" 
                        Style="{StaticResource PrimaryButton}" 
                        HorizontalAlignment="Stretch" Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>