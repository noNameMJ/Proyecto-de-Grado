<UserControl x:Class="Geomatica.Desktop.Views.BarraFiltrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Width="320" Background="#F7F7F7" Margin="12,0,12,0">
        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="Filtros" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            <Button Content="Limpiar" Command="{Binding LimpiarFiltrosCommand}" 
                    HorizontalAlignment="Right" Padding="8,2" FontSize="11"/>
        </DockPanel>
        <TextBlock Text="Palabra clave"/>
        <TextBox Text="{Binding PalabraClave, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>

        <TextBlock Text="Rango temporal"/>
        <StackPanel Orientation="Horizontal" Margin="0,4,0,10">
            <DatePicker SelectedDate="{Binding Desde}" Width="130"/>
            <Button Content="✕" Command="{Binding LimpiarDesdeCommand}"
                    Width="20" Height="20" Padding="0" FontSize="10"
                    VerticalAlignment="Center" Margin="2,0,0,0"
                    ToolTip="Limpiar fecha desde"/>
            <DatePicker SelectedDate="{Binding Hasta}" Width="130" Margin="8,0,0,0"/>
            <Button Content="✕" Command="{Binding LimpiarHastaCommand}"
                    Width="20" Height="20" Padding="0" FontSize="10"
                    VerticalAlignment="Center" Margin="2,0,0,0"
                    ToolTip="Limpiar fecha hasta"/>
        </StackPanel>

        <TextBlock Text="Departamento"/>
        <ComboBox ItemsSource="{Binding Departamentos}" SelectedItem="{Binding SelectedDepartamento, Mode=TwoWay}" DisplayMemberPath="Nombre" SelectedValuePath="Codigo" Margin="0,4,0,10"/>

        <TextBlock Text="Municipio"/>
        <ComboBox ItemsSource="{Binding Areas}" SelectedItem="{Binding AreaInteres, Mode=TwoWay}" DisplayMemberPath="Nombre" SelectedValuePath="Codigo" Margin="0,4,0,10"/>

        <ListBox ItemsSource="{Binding ResultadosResumen}" Height="55"/>
        <Separator Margin="0,12,0,12"/>
        <TextBlock Text="Resultados" FontWeight="SemiBold"/>
        <ListBox ItemsSource="{Binding ResultadosLista}" SelectedItem="{Binding SelectedProyecto, Mode=TwoWay}" DisplayMemberPath="Titulo" Height="195"/>
        <Button Content="Descargar seleccionado" Command="{Binding DescargarCommand}" Height="32" Margin="0,10,0,0"/>
    </StackPanel>
</UserControl>