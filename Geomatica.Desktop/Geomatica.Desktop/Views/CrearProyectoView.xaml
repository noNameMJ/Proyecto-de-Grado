<UserControl x:Class="Geomatica.Desktop.Views.CrearProyectoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="{StaticResource SurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="620" HorizontalAlignment="Left">

                <TextBlock Text="Crear Nuevo Proyecto" Style="{StaticResource PageTitle}" Margin="0,0,0,6"/>
                <Rectangle Height="3" Width="60" Fill="{StaticResource UisGoldBrush}" 
                           HorizontalAlignment="Left" Margin="0,0,0,24"/>

                <!-- Card formulario -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <TextBlock Text="Título" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Titulo}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

                        <TextBlock Text="Descripción (Opcional)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Descripcion}" Height="70" AcceptsReturn="True" 
                                 TextWrapping="Wrap" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

                        <TextBlock Text="Fecha de Inicio" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding FechaInicio}" HorizontalAlignment="Left" 
                                    Width="200" Margin="0,0,0,14"/>

                        <TextBlock Text="Palabra Clave" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding PalabraClave}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

                        <Separator Style="{StaticResource ModernSeparator}"/>

                        <TextBlock Text="Ubicación" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Departamento" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Departamentos}" 
                                          SelectedItem="{Binding SelectedDepartamento}" 
                                          DisplayMemberPath="Nombre" Width="200" 
                                          Style="{StaticResource ModernComboBox}" Margin="0,0,0,14"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Municipio" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Municipios}" 
                                          SelectedItem="{Binding SelectedMunicipio}" 
                                          DisplayMemberPath="Nombre" Width="200" 
                                          Style="{StaticResource ModernComboBox}" Margin="0,0,0,14"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Coordenadas (Opcional — WGS84)" Style="{StaticResource FieldLabel}" Margin="0,4,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Latitud" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding LatStr}" Width="150" 
                                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Longitud" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding LonStr}" Width="150" 
                                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Si se dejan vacíos, no se asignará geometría puntual." 
                                   Style="{StaticResource HintText}" Margin="0,-8,0,14"/>

                        <Separator Style="{StaticResource ModernSeparator}"/>

                        <TextBlock Text="Ruta Archivos (Carpeta)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Ruta}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
                        <TextBlock Text="Ej: C:\Proyectos\Proyecto1" Style="{StaticResource HintText}" Margin="0,0,0,14"/>

                        <!-- Acciones -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="Guardar Proyecto" Command="{Binding GuardarCommand}" 
                                    Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Cancelar" Command="{Binding CancelarCommand}" 
                                    Style="{StaticResource OutlineButton}" Margin="12,0,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
