<UserControl x:Class="Geomatica.Desktop.Views.FichaProyectoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource SurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="700" Margin="32,24" HorizontalAlignment="Center">

                <!-- Barra superior: Volver + Editar -->
                <DockPanel Margin="0,0,0,16">
                    <Button Content="←  Volver al mapa" Command="{Binding VolverCommand}"
                            Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                            FontSize="13"/>
                    <Button Content="✏️  Editar" Command="{Binding EditarCommand}"
                            Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right"
                            Padding="16,8"/>
                </DockPanel>

                <!-- Tarjeta principal -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Franja verde UIS top -->
                        <Rectangle Height="4" Fill="{StaticResource UisGreenBrush}" 
                                   Margin="-24,-24,-24,20" RadiusX="8" RadiusY="8"/>

                        <TextBlock Text="{Binding Titulo}" Style="{StaticResource PageTitle}"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <Separator Style="{StaticResource ModernSeparator}" Margin="0,0,0,16"/>

                        <!-- Descripción -->
                        <TextBlock Text="Descripción" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding Descripcion, TargetNullValue='Sin descripción'}" 
                                   TextWrapping="Wrap" FontSize="14" Margin="0,0,0,18"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource AppFont}"/>

                        <!-- Fecha -->
                        <TextBlock Text="Fecha" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding FechaTexto}" FontSize="14" Margin="0,0,0,18"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource AppFont}"/>

                        <!-- Palabra clave -->
                        <TextBlock Text="Palabra clave" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding PalabraClave, TargetNullValue='—'}" 
                                   FontSize="14" Margin="0,0,0,18"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource AppFont}"/>

                        <!-- Municipio -->
                        <TextBlock Text="Municipio" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding MunicipioNombre, TargetNullValue='No asignado'}" 
                                   FontSize="14" Margin="0,0,0,18"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource AppFont}"/>

                        <!-- Coordenadas -->
                        <TextBlock Text="Coordenadas" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding Coordenadas}" FontSize="14" Margin="0,0,0,18"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource AppFont}"/>

                        <Separator Style="{StaticResource ModernSeparator}" Margin="0,0,0,16"/>

                        <!-- Ruta de archivos -->
                        <TextBlock Text="Ruta de archivos" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding RutaArchivos, TargetNullValue='Sin ruta asignada'}" 
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" 
                                   TextWrapping="Wrap" Margin="0,0,0,10"
                                   FontFamily="{StaticResource AppFont}"/>
                        <Button Content="📁  Abrir carpeta" Command="{Binding AbrirCarpetaCommand}"
                                Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                                Padding="14,7" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
