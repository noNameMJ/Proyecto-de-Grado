<UserControl x:Class="Geomatica.Desktop.Views.MapaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:esri="http://schemas.esri.com/arcgis/runtime/2013"
             xmlns:vm="clr-namespace:Geomatica.Desktop.ViewModels"
             xmlns:views="clr-namespace:Geomatica.Desktop.Views">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel lateral filtros -->
        <views:BarraFiltrosView Grid.Column="0" DataContext="{Binding Filtros}"/>

        <!-- Zona de mapa -->
        <Grid Grid.Column="1">
            <esri:MapView x:Name="controlMapView" Map="{Binding Map}" />

            <!-- Leyenda — estilo ArcGIS Pro -->
            <Border Background="#E8FFFFFF" CornerRadius="6" Padding="12,10"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16"
                    BorderBrush="#20000000" BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Leyenda" FontWeight="SemiBold" FontSize="12" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource AppFont}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource UisGreenBrush}"
                                 Stroke="White" StrokeThickness="1.5"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Proyecto geomático" FontSize="11" 
                                   VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource AppFont}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="14" Height="10"
                                   Fill="#28006633" Stroke="#B4006633" StrokeThickness="1"
                                   RadiusX="2" RadiusY="2"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Municipio con proyecto" FontSize="11" 
                                   VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource AppFont}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Botón Home — estilo ArcGIS tool button -->
            <Button x:Name="HomeButton"
                    Content="🏠" ToolTip="Restaurar vista inicial"
                    Style="{StaticResource MapToolButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="16"
                    Command="{Binding HomeCommand}"/>
        </Grid>
    </Grid>
</UserControl>
