<UserControl x:Class="Geomatica.Desktop.Views.MapaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:esri="http://schemas.esri.com/arcgis/runtime/2013"
             xmlns:vm="clr-namespace:Geomatica.Desktop.ViewModels"
             xmlns:views="clr-namespace:Geomatica.Desktop.Views">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Barra de filtros: bind al Filtros del ViewModel (no resource local) -->
        <views:BarraFiltrosView Grid.Column="0" DataContext="{Binding Filtros}"/>

        <!-- Mapa enlazado a tu VM (DataContext) -->
        <Grid Grid.Column="1">
            <esri:MapView x:Name="controlMapView" Map="{Binding Map}" />

            <!-- Leyenda -->
            <Border Background="#E0FFFFFF" CornerRadius="4" Padding="8,6"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12">
                <StackPanel>
                    <TextBlock Text="Leyenda" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Ellipse Width="10" Height="10" Fill="OrangeRed"
                                 Stroke="White" StrokeThickness="1.5"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Proyecto geomático" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="14" Height="10"
                                   Fill="#282196F3" Stroke="#B42196F3" StrokeThickness="1"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Municipio con proyecto" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Botón Home (esquina inferior derecha) ligado al comando en el VM -->
            <Button x:Name="HomeButton"
                    Width="44" Height="44"
                    FontSize="18"
                    Content="🏠"
                    ToolTip="Restaurar vista inicial"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="12"
                    Command="{Binding HomeCommand}"
                    Background="White"
                    Opacity="0.9"
                    />
        </Grid>
    </Grid>
</UserControl>
